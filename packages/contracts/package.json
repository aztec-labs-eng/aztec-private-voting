{
  "name": "@app/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "PrivateVoting Noir contract + generated TypeScript artifact.",
  "exports": {
    "./PrivateVoting": "./artifacts/PrivateVoting.ts"
  },
